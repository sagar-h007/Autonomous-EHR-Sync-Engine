# ── Core ignores ──────────────────────────────────────────────────────────────
node_modules/
**/node_modules/

# Build outputs
dist/
**/dist/

# ── Secrets — NEVER commit ────────────────────────────────────────────────────
.env
**/.env

# ── Prisma ────────────────────────────────────────────────────────────────────
# Generated client — recreated via `prisma generate`
**/generated/
# Keep migrations/ committed — it's part of schema history

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
**/*.tsbuildinfo

# ── Playwright ────────────────────────────────────────────────────────────────
**/test-results/
**/playwright-report/
**/playwright/.cache/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
Thumbs.db

# ── Editors ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Docker ────────────────────────────────────────────────────────────────────
# Keep docker-compose.yml committed (dev convenience)
# Ignore local override if you create one
docker-compose.override.yml
