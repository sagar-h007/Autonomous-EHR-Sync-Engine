# =============================================================================
# EHR Sync Engine — Backend Environment Variables
# =============================================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values — NEVER commit .env (it's in .gitignore)
# =============================================================================

NODE_ENV=development
PORT=4000

# ── Option A: Docker Compose (instant local Postgres, zero config) ────────────
# Run: docker-compose up -d  (spins up Postgres on port 5433)
# DATABASE_URL="postgresql://ehr_user:ehr_password@localhost:5433/ehr_sync_db?schema=public"

# ── Option B: Neon (free cloud Postgres, no local setup) ──────────────────────
# Sign up at https://neon.tech → copy the connection string from your dashboard
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.neon.tech/neondb?sslmode=require"

# ── Option C: Local Postgres ───────────────────────────────────────────────────
# DATABASE_URL="postgresql://postgres:password@localhost:5432/ehr_sync_db?schema=public"

# Active DATABASE_URL — uncomment / replace the one you're using:
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins in production
# e.g. ALLOWED_ORIGINS=https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Playwright ────────────────────────────────────────────────────────────────
# Optional: override the legacy UI mock HTML path (auto-resolved if blank)
# LEGACY_UI_PATH=/absolute/path/to/ehr-sync-engine/legacy_ui_mock/index.html

# ── FHIR Server ───────────────────────────────────────────────────────────────
# Override to use a private FHIR server instead of the public HAPI test server
# HAPI_FHIR_URL=http://hapi.fhir.org/baseR4
